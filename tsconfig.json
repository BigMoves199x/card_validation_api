{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "types": ["node", "jest"],

    "rootDir": "./",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,

    "sourceMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
   "include": ["src", "tests", "src/tests/card.test.ts", "jest.config.ts"] 
}